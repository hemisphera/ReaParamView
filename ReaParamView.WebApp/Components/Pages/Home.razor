@page "/"
@rendermode InteractiveServer
@using ReaParamView.WebApp.Services
@inject ParameterDisplayService DisplayService
@implements IDisposable

<PageTitle>Parameter Display</PageTitle>

<div class="pd-wrapper">
    @if (DisplayService.CurrentMessage is { } msg)
    {
        <header class="pd-header">
            <div class="pd-header-label">Track</div>
            <div class="pd-header-name">@msg.TrackName</div>
            <div class="pd-header-count">@Math.Min(msg.Envelopes?.Count ?? 0, 8) parameters</div>
        </header>

        <div class="pd-grid">
            @foreach (var param in (msg.Envelopes ?? []).Take(8))
            {
                var pct = Math.Clamp(param.Percentage, 0.0, 1.0) * 100.0;
                <div class="pd-card">
                    <div class="pd-card-name" title="@param.Name">@param.Name</div>
                    <div class="pd-card-pct">@pct.ToString("F1")%</div>
                    <div class="pd-bar-track">
                        <div class="pd-bar-fill"
                             style="width: @pct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div class="pd-card-value">@param.Value.ToString("F4")</div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="pd-idle">
            <div class="pd-idle-pulse"></div>
            <p>Waiting for parameters&hellip;</p>
        </div>
    }
</div>

@code {

    protected override void OnInitialized()
    {
        DisplayService.OnChange += HandleUpdate;
    }

    private void HandleUpdate()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DisplayService.OnChange -= HandleUpdate;
    }

}
